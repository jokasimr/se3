# zero angle yields identity quaternion
query IIII
SELECT
  (quat_from_axis_angle(struct_pack(x:=1.0, y:=0.0, z:=0.0), 0.0)).w,
  (quat_from_axis_angle(struct_pack(x:=1.0, y:=0.0, z:=0.0), 0.0)).x,
  (quat_from_axis_angle(struct_pack(x:=1.0, y:=0.0, z:=0.0), 0.0)).y,
  (quat_from_axis_angle(struct_pack(x:=1.0, y:=0.0, z:=0.0), 0.0)).z;
----
1.0	0.0	0.0	0.0

# qmul identity
query IIII
SELECT
  (qmul(struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0), struct_pack(w:=0.0, x:=1.0, y:=2.0, z:=3.0))).w,
  (qmul(struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0), struct_pack(w:=0.0, x:=1.0, y:=2.0, z:=3.0))).x,
  (qmul(struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0), struct_pack(w:=0.0, x:=1.0, y:=2.0, z:=3.0))).y,
  (qmul(struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0), struct_pack(w:=0.0, x:=1.0, y:=2.0, z:=3.0))).z;
----
0.0	1.0	2.0	3.0

# qmul with conjugate yields (norm2,0,0,0)
query IIII
SELECT
  (qmul(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0), qconj(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0)))).w,
  (qmul(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0), qconj(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0)))).x,
  (qmul(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0), qconj(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0)))).y,
  (qmul(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0), qconj(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0)))).z;
----
30.0	0.0	0.0	0.0

# quat_from_axis_angle normalizes axis
query I
SELECT abs(qnorm2(quat_from_axis_angle(struct_pack(x:=2.0, y:=0.0, z:=0.0), pi())) - 1.0) < 1e-12;
----
true

# quat_from_axis_angle returns NULL for zero axis
query I
SELECT quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), pi()/2.0) IS NULL;
----
true

# se3_from_axis_angle returns NULL for zero axis
query I
SELECT se3_from_axis_angle(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(x:=0.0, y:=0.0, z:=0.0), pi()/2.0) IS NULL;
----
true

# se3_from_axis_angle normalizes axis (scaled axis gives same transform)
query I
SELECT
  abs((se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=2.0, y:=0.0, z:=0.0), pi()),
    struct_pack(x:=0.0, y:=1.0, z:=0.0)
  )).x - 0.0) < 1e-12
  AND abs((se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=2.0, y:=0.0, z:=0.0), pi()),
    struct_pack(x:=0.0, y:=1.0, z:=0.0)
  )).y + 1.0) < 1e-12
  AND abs((se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=2.0, y:=0.0, z:=0.0), pi()),
    struct_pack(x:=0.0, y:=1.0, z:=0.0)
  )).z - 0.0) < 1e-12;
----
true

# tiny non-zero axis should normalize (not NULL) and produce unit quaternion
query I
SELECT abs(qnorm2(quat_from_axis_angle(struct_pack(x:=1e-300, y:=0.0, z:=0.0), pi()/2.0)) - 1.0) < 1e-12;
----
true

# huge axis should normalize robustly (not overflow to NaN)
query I
SELECT abs(qnorm2(quat_from_axis_angle(struct_pack(x:=1e308, y:=0.0, z:=0.0), pi()/2.0)) - 1.0) < 1e-12;
----
true

# se3_from_axis_angle with tiny non-zero axis should be valid
query I
SELECT se3_from_axis_angle(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(x:=1e-300, y:=0.0, z:=0.0), pi()/2.0) IS NOT NULL;
----
true

# se3_from_axis_angle with huge axis should be valid
query I
SELECT se3_from_axis_angle(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(x:=1e308, y:=0.0, z:=0.0), pi()/2.0) IS NOT NULL;
----
true

# axis-angle constructors normalize subnormal multi-component axes without reciprocal overflow
query I
WITH rotations AS (
  SELECT
    quat_from_axis_angle(vvec(1e-320, 2e-320, -1e-320), pi()/2.0) AS q,
    se3_from_axis_angle(vvec(1.0, 2.0, 3.0), vvec(1e-320, 2e-320, -1e-320), pi()/2.0) AS w,
    quat_from_axis_angle(vvec(1.0, 2.0, -1.0), pi()/2.0) AS expected
)
SELECT
  q IS NOT NULL
  AND w IS NOT NULL
  AND abs(qnorm2(q) - 1.0) < 1e-12
  AND vnorm(vsub(q, expected)) < 1e-12
  AND vnorm(vsub(w.q, expected)) < 1e-12
FROM rotations;
----
true

# axis-angle constructors normalize axes whose Euclidean norm exceeds the double range
query I
WITH rotations AS (
  SELECT
    quat_from_axis_angle(vvec(1.7e308, 1.7e308, 0.0), pi()/2.0) AS q,
    se3_from_axis_angle(vvec(1.0, 2.0, 3.0), vvec(1.7e308, 1.7e308, 0.0), pi()/2.0) AS w,
    quat_from_axis_angle(vvec(1.0, 1.0, 0.0), pi()/2.0) AS expected
)
SELECT
  q IS NOT NULL
  AND w IS NOT NULL
  AND abs(qnorm2(q) - 1.0) < 1e-12
  AND vnorm(vsub(q, expected)) < 1e-12
  AND vnorm(vsub(w.q, expected)) < 1e-12
FROM rotations;
----
true

# se3_make with identity rotation is pure translation
query III
SELECT
  (se3_apply(se3_make(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0)),
               struct_pack(x:=4.0, y:=5.0, z:=6.0))).x,
  (se3_apply(se3_make(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0)),
               struct_pack(x:=4.0, y:=5.0, z:=6.0))).y,
  (se3_apply(se3_make(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0)),
               struct_pack(x:=4.0, y:=5.0, z:=6.0))).z;
----
5.0	7.0	9.0

# translate then rotate: t=(1,0,0), R=90deg about z, p=(0,0,0) -> (0,1,0)
query III
SELECT
  round((se3_apply(
    se3_from_axis_angle(struct_pack(x:=1.0, y:=0.0, z:=0.0), struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).x, 6),
  round((se3_apply(
    se3_from_axis_angle(struct_pack(x:=1.0, y:=0.0, z:=0.0), struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).y, 6),
  round((se3_apply(
    se3_from_axis_angle(struct_pack(x:=1.0, y:=0.0, z:=0.0), struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).z, 6);
----
0.0	1.0	0.0

# compose translate after W with rotation: t' = t + R^-1 t2
query III
SELECT
  round((se3_apply(
    se3_compose(
      struct_pack(x:=1.0, y:=0.0, z:=0.0),
      se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)
    ),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).x, 6),
  round((se3_apply(
    se3_compose(
      struct_pack(x:=1.0, y:=0.0, z:=0.0),
      se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)
    ),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).y, 6),
  round((se3_apply(
    se3_compose(
      struct_pack(x:=1.0, y:=0.0, z:=0.0),
      se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)
    ),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).z, 6);
----
1.0	0.0	0.0

# compose rotate after W with translation
query III
SELECT
  round((se3_apply(
    se3_compose(
      quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
      se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0))
    ),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).x, 6),
  round((se3_apply(
    se3_compose(
      quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
      se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0))
    ),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).y, 6),
  round((se3_apply(
    se3_compose(
      quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
      se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0))
    ),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).z, 6);
----
0.0	1.0	0.0

# null propagation for constructors
query I
SELECT se3_make(NULL, struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0)) IS NULL;
----
true

query I
