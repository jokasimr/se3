true	true	true	true

query IIIIIIII
SELECT
  isinf(vnorm(vvec('inf'::DOUBLE, 0.0, 0.0))),
  isinf(vnorm(vvec('inf'::DOUBLE, 0.0, 0.0, 0.0))),
  isnan(vnorm(vvec('nan'::DOUBLE, 0.0, 0.0))),
  isnan(vnorm(vvec('nan'::DOUBLE, 0.0, 0.0, 0.0))),
  isnan((vnormalize(vvec('inf'::DOUBLE, 0.0, 0.0))).x),
  isnan((vnormalize(vvec('inf'::DOUBLE, 0.0, 0.0, 0.0))).w),
  isnan((vnormalize(vvec('nan'::DOUBLE, 0.0, 0.0))).x),
  isnan((vnormalize(vvec('nan'::DOUBLE, 0.0, 0.0, 0.0))).w);
----
true	true	true	true	true	true	true	true

