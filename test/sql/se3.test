# randomized property: theta and theta+2pi rotations are equivalent
statement ok
SELECT setseed(0.13579);

query I
WITH r AS (
  SELECT
    (random()*2.0-1.0) AS ax,
    (random()*2.0-1.0) AS ay,
    (random()*2.0-1.0) AS az,
    (random()*2.0-1.0) AS px,
    (random()*2.0-1.0) AS py,
    (random()*2.0-1.0) AS pz
  FROM range(200)
), n AS (
  SELECT
    ax, ay, az, px, py, pz,
    sqrt(ax*ax + ay*ay + az*az) AS an
  FROM r
), u AS (
  SELECT
    ax/an AS ux,
    ay/an AS uy,
    az/an AS uz,
    px, py, pz
  FROM n
  WHERE an > 1e-9
), a AS (
  SELECT
    ux, uy, uz, px, py, pz,
    1.0 AS th1,
    1.0 + 2.0*pi() AS th2
  FROM u
)
SELECT bool_and(
  abs((se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=ux, y:=uy, z:=uz), th1),
    struct_pack(x:=px, y:=py, z:=pz)
  )).x - (se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=ux, y:=uy, z:=uz), th2),
    struct_pack(x:=px, y:=py, z:=pz)
  )).x) < 1e-10
  AND abs((se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=ux, y:=uy, z:=uz), th1),
    struct_pack(x:=px, y:=py, z:=pz)
  )).y - (se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=ux, y:=uy, z:=uz), th2),
    struct_pack(x:=px, y:=py, z:=pz)
  )).y) < 1e-10
  AND abs((se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=ux, y:=uy, z:=uz), th1),
    struct_pack(x:=px, y:=py, z:=pz)
  )).z - (se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=ux, y:=uy, z:=uz), th2),
    struct_pack(x:=px, y:=py, z:=pz)
  )).z) < 1e-10
)
FROM a;
----
true

