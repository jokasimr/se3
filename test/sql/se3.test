# se3_apply(quat, vec3): pure rotation
query III
SELECT
  round((se3_apply(
    quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).x, 6),
  round((se3_apply(
    quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).y, 6),
  round((se3_apply(
    quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).z, 6);
