# name: test/sql/se3.test
# description: test se3 extension
# group: [sql]

# Require statement will ensure this test is run with this extension loaded
require se3

# function metadata is attached to all se3 scalar overloads
query IIII
WITH names(function_name) AS (
  VALUES
    ('vvec'), ('vadd'), ('vsub'), ('vscale'), ('vdot'), ('vnorm2'), ('vnorm'), ('vnormalize'),
    ('vcross'), ('vcos_angle'), ('vangle'), ('vproj'), ('vrej'), ('quat_from_axis_angle'),
    ('qmul'), ('qconj'), ('qnorm2'), ('se3_identity'), ('se3_make'), ('se3_from_axis_angle'),
    ('se3_apply'), ('se3_inv'), ('se3_compose')
)
SELECT count(*), count(description), count(examples), count(categories)
FROM duckdb_functions()
WHERE function_type = 'scalar'
  AND function_name IN (SELECT function_name FROM names);
----
47	47	47	47

# vvec overload metadata is matched by concrete parameter types
query II
SELECT
  sum(CASE WHEN array_length(parameter_types) = 3
            AND parameters[1] = 'x'
            AND parameters[2] = 'y'
            AND parameters[3] = 'z'
            AND description = 'Creates a vec3 from x, y, and z components.'
           THEN 1 ELSE 0 END),
  sum(CASE WHEN array_length(parameter_types) = 4
            AND parameters[1] = 'w'
            AND parameters[2] = 'x'
            AND parameters[3] = 'y'
            AND parameters[4] = 'z'
            AND description = 'Creates a vec4 from w, x, y, and z components.'
           THEN 1 ELSE 0 END)
FROM duckdb_functions()
WHERE function_type = 'scalar'
  AND function_name = 'vvec';
----
1	1

# se3_compose uses one semantic description while exposing all accepted representations
query III
SELECT
  count(*),
  count(DISTINCT parameter_types::VARCHAR),
  sum(CASE WHEN parameters[1] = 'W2'
            AND parameters[2] = 'W1'
            AND description = 'Composes two transformations, applying W1 first and then W2. W1 and W2 can each be a full transformation struct, a vec3 representing only the translation part, or a quat representing only the rotation part.'
           THEN 1 ELSE 0 END)
FROM duckdb_functions()
WHERE function_type = 'scalar'
  AND function_name = 'se3_compose';
----
9	9	9

# quat_from_axis_angle produces unit quaternion for unit axis
query I
SELECT abs(qnorm2(quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)) - 1.0) < 1e-12;
----
true

# qconj flips vector part
query IIII
SELECT
  (qconj(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0))).w,
  (qconj(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0))).x,
  (qconj(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0))).y,
  (qconj(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0))).z;
----
1.0	-2.0	-3.0	-4.0

# se3_identity leaves points unchanged
query III
SELECT
  (se3_apply(se3_identity(), struct_pack(x:=1.0, y:=2.0, z:=3.0))).x,
  (se3_apply(se3_identity(), struct_pack(x:=1.0, y:=2.0, z:=3.0))).y,
  (se3_apply(se3_identity(), struct_pack(x:=1.0, y:=2.0, z:=3.0))).z;
----
1.0	2.0	3.0

# se3_from_axis_angle with 90deg about +Z rotates +X to +Y
query III
SELECT
  round((se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).x, 6),
  round((se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).y, 6),
  round((se3_apply(
    se3_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=0.0), struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).z, 6);
----
0.0	1.0	0.0

# compose translate after W
query III
SELECT
  (se3_apply(
    se3_compose(struct_pack(x:=1.0, y:=2.0, z:=3.0), se3_identity()),
    struct_pack(x:=4.0, y:=5.0, z:=6.0)
  )).x,
  (se3_apply(
    se3_compose(struct_pack(x:=1.0, y:=2.0, z:=3.0), se3_identity()),
    struct_pack(x:=4.0, y:=5.0, z:=6.0)
  )).y,
  (se3_apply(
    se3_compose(struct_pack(x:=1.0, y:=2.0, z:=3.0), se3_identity()),
    struct_pack(x:=4.0, y:=5.0, z:=6.0)
  )).z;
----
5.0	7.0	9.0

# compose rotate after W
query III
SELECT
  round((se3_apply(
    se3_compose(quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0), se3_identity()),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).x, 6),
  round((se3_apply(
    se3_compose(quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0), se3_identity()),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).y, 6),
  round((se3_apply(
    se3_compose(quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0), se3_identity()),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).z, 6);
----
0.0	1.0	0.0

# null propagation: any NULL input yields NULL output
query I
SELECT se3_identity() IS NULL;
----
false

# null struct outputs must also expose NULL fields through struct_extract/dot access
query II
WITH r AS (
  SELECT se3_apply(
    struct_pack(x:=NULL, y:=2.0, z:=3.0),
    struct_pack(x:=1.0, y:=2.0, z:=3.0)
  ) AS v
)
SELECT v IS NULL, v.x IS NULL FROM r;
----
true	true

query II
WITH r AS (
  SELECT qconj(CAST(NULL AS STRUCT(w DOUBLE, x DOUBLE, y DOUBLE, z DOUBLE))) AS q
)
SELECT q IS NULL, q.w IS NULL FROM r;
----
true	true

query III
WITH r AS (
  SELECT se3_from_axis_angle(
    struct_pack(x:=1.0, y:=2.0, z:=3.0),
    struct_pack(x:=0.0, y:=0.0, z:=0.0),
    1.0
  ) AS w
)
SELECT w IS NULL,
       struct_extract(w, 't') IS NULL,
       struct_extract(struct_extract(w, 't'), 'x') IS NULL
FROM r;
----
true	true	true

query III
WITH r AS (
  SELECT se3_from_axis_angle(
    struct_pack(x:=1.0, y:=2.0, z:=3.0),
    struct_pack(x:=0.0, y:=0.0, z:=0.0),
    1.0
  ) AS w
)
SELECT w IS NULL,
       struct_extract(w, 'q') IS NULL,
       struct_extract(struct_extract(w, 'q'), 'w') IS NULL
FROM r;
----
true	true	true

query IIII
WITH mix(id, v) AS (
  VALUES
    (1, CAST(NULL AS STRUCT(x DOUBLE, y DOUBLE, z DOUBLE))),
    (2, struct_pack(x:=2.0, y:=20.0, z:=200.0)),
    (3, struct_pack(x:=NULL, y:=30.0, z:=300.0)),
    (4, struct_pack(x:=4.0, y:=40.0, z:=400.0))
),
r AS (
  SELECT id, se3_apply(v, struct_pack(x:=1.0, y:=1.0, z:=1.0)) AS out
  FROM mix
)
SELECT id, out IS NULL, out.x IS NULL, out.x
FROM r
ORDER BY id;
----
1	true	true	NULL
2	false	false	3.0
3	true	true	NULL
4	false	false	5.0

query I
SELECT se3_apply(CAST(NULL AS STRUCT(
    t STRUCT(x DOUBLE, y DOUBLE, z DOUBLE),
    q STRUCT(w DOUBLE, x DOUBLE, y DOUBLE, z DOUBLE)
  )), struct_pack(x:=1.0, y:=2.0, z:=3.0)) IS NULL;
----
true

query I
SELECT se3_apply(struct_pack(
  t:=struct_pack(x:=1.0, y:=2.0, z:=3.0),
  q:=struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0)
), CAST(NULL AS STRUCT(x DOUBLE, y DOUBLE, z DOUBLE))) IS NULL;
