true

# property: combine rotations (q2 * q1) then apply to point equals sequential application
statement ok
SELECT setseed(0.97531);

query I
WITH r AS (
  SELECT
    (random()*2.0-1.0) AS ax,
    (random()*2.0-1.0) AS ay,
    (random()*2.0-1.0) AS az,
    (random()*2.0-1.0) AS px,
    (random()*2.0-1.0) AS py,
    (random()*2.0-1.0) AS pz
  FROM range(200)
), n AS (
  SELECT
    ax, ay, az, px, py, pz,
    sqrt(ax*ax + ay*ay + az*az) AS an
  FROM r
), u AS (
  SELECT
    ax/an AS ux,
    ay/an AS uy,
    az/an AS uz,
    px, py, pz
  FROM n
  WHERE an > 1e-9
), q AS (
  SELECT
    quat_from_axis_angle(struct_pack(x:=ux, y:=uy, z:=uz), 1.0) AS q1,
    quat_from_axis_angle(struct_pack(x:=ux, y:=uy, z:=uz), 2.0*pi() - 1.0) AS q2,
    px, py, pz
  FROM u
)
SELECT bool_and(
  abs((se3_apply(
        se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), qmul(q2, q1)),
        struct_pack(x:=px, y:=py, z:=pz)
      )).x - (se3_apply(
        se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q2),
        se3_apply(
          se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q1),
          struct_pack(x:=px, y:=py, z:=pz)
        )
      )).x) < 1e-10
  AND abs((se3_apply(
        se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), qmul(q2, q1)),
        struct_pack(x:=px, y:=py, z:=pz)
      )).y - (se3_apply(
        se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q2),
        se3_apply(
          se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q1),
          struct_pack(x:=px, y:=py, z:=pz)
        )
      )).y) < 1e-10
  AND abs((se3_apply(
        se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), qmul(q2, q1)),
        struct_pack(x:=px, y:=py, z:=pz)
      )).z - (se3_apply(
        se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q2),
        se3_apply(
          se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q1),
          struct_pack(x:=px, y:=py, z:=pz)
        )
      )).z) < 1e-10
)
FROM q;
----
true

