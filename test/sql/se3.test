0.0	1.0	0.0

# se3_apply(quat, vec3) avoids intermediate overflow for extreme finite vectors
query I
WITH rotated AS (
  SELECT
    se3_apply(vvec(0.0, 0.0, 0.0, 1.0), vvec(1e308, 0.0, 0.0)) AS exact_pi,
    se3_apply(quat_from_axis_angle(vvec(0.0, 0.0, 1.0), pi()), vvec(1e308, 0.0, 0.0)) AS axis_pi,
    se3_apply(vvec(sqrt(0.5), 0.0, 0.0, sqrt(0.5)), vvec(1.7e308, 0.0, 0.0)) AS quarter_turn
)
SELECT
  NOT isinf(exact_pi.x) AND NOT isnan(exact_pi.x)
  AND NOT isinf(exact_pi.y) AND NOT isnan(exact_pi.y)
  AND NOT isinf(exact_pi.z) AND NOT isnan(exact_pi.z)
  AND abs(exact_pi.x / 1e308 + 1.0) < 1e-12
  AND abs(exact_pi.y / 1e308) < 1e-12
  AND abs(exact_pi.z / 1e308) < 1e-12
  AND NOT isinf(axis_pi.x) AND NOT isnan(axis_pi.x)
  AND NOT isinf(axis_pi.y) AND NOT isnan(axis_pi.y)
  AND NOT isinf(axis_pi.z) AND NOT isnan(axis_pi.z)
  AND abs(axis_pi.x / 1e308 + 1.0) < 1e-12
  AND abs(axis_pi.y / 1e308) < 1e-12
  AND abs(axis_pi.z / 1e308) < 1e-12
  AND NOT isinf(quarter_turn.x) AND NOT isnan(quarter_turn.x)
  AND NOT isinf(quarter_turn.y) AND NOT isnan(quarter_turn.y)
  AND NOT isinf(quarter_turn.z) AND NOT isnan(quarter_turn.z)
  AND abs(quarter_turn.x / 1.7e308) < 1e-12
  AND abs(quarter_turn.y / 1.7e308 - 1.0) < 1e-12
  AND abs(quarter_turn.z / 1.7e308) < 1e-12
FROM rotated;
----
true

# se3_apply(W, vec3) avoids intermediate overflow for extreme finite vectors
query I
WITH rotated AS (
  SELECT
    se3_apply(se3_make(vvec(0.0, 0.0, 0.0), vvec(0.0, 0.0, 0.0, 1.0)), vvec(1e308, 0.0, 0.0)) AS exact_pi,
    se3_apply(se3_make(vvec(0.0, 0.0, 0.0), vvec(sqrt(0.5), 0.0, 0.0, sqrt(0.5))), vvec(1.7e308, 0.0, 0.0)) AS quarter_turn
)
SELECT
  NOT isinf(exact_pi.x) AND NOT isnan(exact_pi.x)
  AND NOT isinf(exact_pi.y) AND NOT isnan(exact_pi.y)
  AND NOT isinf(exact_pi.z) AND NOT isnan(exact_pi.z)
  AND abs(exact_pi.x / 1e308 + 1.0) < 1e-12
  AND abs(exact_pi.y / 1e308) < 1e-12
  AND abs(exact_pi.z / 1e308) < 1e-12
  AND NOT isinf(quarter_turn.x) AND NOT isnan(quarter_turn.x)
  AND NOT isinf(quarter_turn.y) AND NOT isnan(quarter_turn.y)
  AND NOT isinf(quarter_turn.z) AND NOT isnan(quarter_turn.z)
  AND abs(quarter_turn.x / 1.7e308) < 1e-12
  AND abs(quarter_turn.y / 1.7e308 - 1.0) < 1e-12
  AND abs(quarter_turn.z / 1.7e308) < 1e-12
FROM rotated;
----
true

# se3_compose overloads using inverse rotation avoid intermediate overflow
query I
WITH composed AS (
  SELECT
    se3_compose(vvec(1e308, 0.0, 0.0), vvec(0.0, 0.0, 0.0, 1.0)) AS tq,
    se3_compose(se3_make(vvec(1e308, 0.0, 0.0), vvec(1.0, 0.0, 0.0, 0.0)), vvec(0.0, 0.0, 0.0, 1.0)) AS wq,
    se3_compose(se3_make(vvec(1e308, 0.0, 0.0), vvec(1.0, 0.0, 0.0, 0.0)), se3_make(vvec(0.0, 0.0, 0.0), vvec(0.0, 0.0, 0.0, 1.0))) AS ww,
    se3_compose(vvec(1e308, 0.0, 0.0), se3_make(vvec(0.0, 0.0, 0.0), vvec(0.0, 0.0, 0.0, 1.0))) AS tw
)
SELECT
  NOT isinf(tq.t.x) AND NOT isnan(tq.t.x)
  AND NOT isinf(tq.t.y) AND NOT isnan(tq.t.y)
  AND NOT isinf(tq.t.z) AND NOT isnan(tq.t.z)
  AND abs(tq.t.x / 1e308 + 1.0) < 1e-12
  AND abs(tq.t.y / 1e308) < 1e-12
  AND abs(tq.t.z / 1e308) < 1e-12
  AND NOT isinf(wq.t.x) AND NOT isnan(wq.t.x)
  AND NOT isinf(wq.t.y) AND NOT isnan(wq.t.y)
  AND NOT isinf(wq.t.z) AND NOT isnan(wq.t.z)
  AND NOT isinf(ww.t.x) AND NOT isnan(ww.t.x)
  AND NOT isinf(ww.t.y) AND NOT isnan(ww.t.y)
  AND NOT isinf(ww.t.z) AND NOT isnan(ww.t.z)
  AND NOT isinf(tw.t.x) AND NOT isnan(tw.t.x)
  AND NOT isinf(tw.t.y) AND NOT isnan(tw.t.y)
  AND NOT isinf(tw.t.z) AND NOT isnan(tw.t.z)
  AND abs(wq.t.x / 1e308 + 1.0) < 1e-12
  AND abs(wq.t.y / 1e308) < 1e-12
  AND abs(wq.t.z / 1e308) < 1e-12
  AND abs(ww.t.x / 1e308 + 1.0) < 1e-12
  AND abs(ww.t.y / 1e308) < 1e-12
  AND abs(ww.t.z / 1e308) < 1e-12
  AND abs(tw.t.x / 1e308 + 1.0) < 1e-12
  AND abs(tw.t.y / 1e308) < 1e-12
  AND abs(tw.t.z / 1e308) < 1e-12
FROM composed;
----
true

# se3_compose overloads using inverse rotation handle extreme finite quarter turns
query I
WITH composed AS (
  SELECT
    se3_compose(vvec(1.7e308, 0.0, 0.0), vvec(sqrt(0.5), 0.0, 0.0, sqrt(0.5))) AS tq,
    se3_compose(se3_make(vvec(1.7e308, 0.0, 0.0), vvec(1.0, 0.0, 0.0, 0.0)), vvec(sqrt(0.5), 0.0, 0.0, sqrt(0.5))) AS wq,
    se3_compose(se3_make(vvec(1.7e308, 0.0, 0.0), vvec(1.0, 0.0, 0.0, 0.0)), se3_make(vvec(0.0, 0.0, 0.0), vvec(sqrt(0.5), 0.0, 0.0, sqrt(0.5)))) AS ww,
    se3_compose(vvec(1.7e308, 0.0, 0.0), se3_make(vvec(0.0, 0.0, 0.0), vvec(sqrt(0.5), 0.0, 0.0, sqrt(0.5)))) AS tw
)
SELECT
  NOT isinf(tq.t.x) AND NOT isnan(tq.t.x)
  AND NOT isinf(tq.t.y) AND NOT isnan(tq.t.y)
  AND NOT isinf(tq.t.z) AND NOT isnan(tq.t.z)
  AND NOT isinf(wq.t.x) AND NOT isnan(wq.t.x)
  AND NOT isinf(wq.t.y) AND NOT isnan(wq.t.y)
  AND NOT isinf(wq.t.z) AND NOT isnan(wq.t.z)
  AND NOT isinf(ww.t.x) AND NOT isnan(ww.t.x)
  AND NOT isinf(ww.t.y) AND NOT isnan(ww.t.y)
  AND NOT isinf(ww.t.z) AND NOT isnan(ww.t.z)
  AND NOT isinf(tw.t.x) AND NOT isnan(tw.t.x)
  AND NOT isinf(tw.t.y) AND NOT isnan(tw.t.y)
  AND NOT isinf(tw.t.z) AND NOT isnan(tw.t.z)
  AND abs(tq.t.x / 1.7e308) < 1e-12
  AND abs(tq.t.y / 1.7e308 + 1.0) < 1e-12
  AND abs(tq.t.z / 1.7e308) < 1e-12
  AND abs(wq.t.x / 1.7e308) < 1e-12
  AND abs(wq.t.y / 1.7e308 + 1.0) < 1e-12
  AND abs(wq.t.z / 1.7e308) < 1e-12
  AND abs(ww.t.x / 1.7e308) < 1e-12
  AND abs(ww.t.y / 1.7e308 + 1.0) < 1e-12
  AND abs(ww.t.z / 1.7e308) < 1e-12
  AND abs(tw.t.x / 1.7e308) < 1e-12
  AND abs(tw.t.y / 1.7e308 + 1.0) < 1e-12
  AND abs(tw.t.z / 1.7e308) < 1e-12
FROM composed;
----
true

# qrotate returns floating-point overflow when the true rotated component overflows
query I
WITH rotated AS (
  SELECT se3_apply(quat_from_axis_angle(vvec(0.0, 0.0, 1.0), pi()/4.0), vvec(1.7e308, 1.7e308, 0.0)) AS p
)
SELECT
  NOT isinf(p.x) AND NOT isnan(p.x)
  AND abs(p.x / 1.7e308) < 1e-12
  AND isinf(p.y) AND p.y > 0.0
  AND NOT isinf(p.z) AND NOT isnan(p.z)
  AND p.z = 0.0
FROM rotated;
----
true

# qrotate keeps non-finite inputs on the fast floating-point path
query I
WITH rotated AS (
  SELECT
    se3_apply(vvec(0.0, 0.0, 0.0, 1.0), vvec('inf'::DOUBLE, 0.0, 0.0)) AS inf_pi,
    se3_apply(vvec(0.0, 0.0, 0.0, 1.0), vvec('nan'::DOUBLE, 0.0, 0.0)) AS nan_pi
)
SELECT
  isnan(inf_pi.x) AND isnan(inf_pi.y) AND isnan(inf_pi.z)
  AND isnan(nan_pi.x) AND isnan(nan_pi.y) AND isnan(nan_pi.z)
FROM rotated;
----
true

# qrotate handles tiny and subnormal finite vectors
query I
WITH rotated AS (
  SELECT
    se3_apply(vvec(0.0, 0.0, 0.0, 1.0), vvec(1e-308, 0.0, 0.0)) AS tiny_pi,
    se3_apply(vvec(sqrt(0.5), 0.0, 0.0, sqrt(0.5)), vvec(1e-308, 0.0, 0.0)) AS tiny_quarter_turn,
    se3_apply(vvec(0.0, 0.0, 0.0, 1.0), vvec(5e-324, 0.0, 0.0)) AS min_subnormal_pi,
    se3_apply(vvec(sqrt(0.5), 0.0, 0.0, sqrt(0.5)), vvec(5e-324, 0.0, 0.0)) AS min_subnormal_quarter_turn
)
SELECT
  NOT isinf(tiny_pi.x) AND NOT isnan(tiny_pi.x)
  AND NOT isinf(tiny_quarter_turn.x) AND NOT isnan(tiny_quarter_turn.x)
  AND abs(tiny_pi.x / 1e-308 + 1.0) < 1e-12
  AND abs(tiny_pi.y / 1e-308) < 1e-12
  AND abs(tiny_pi.z / 1e-308) < 1e-12
  AND abs(tiny_quarter_turn.x / 1e-308) < 1e-12
  AND abs(tiny_quarter_turn.y / 1e-308 - 1.0) < 1e-12
  AND abs(tiny_quarter_turn.z / 1e-308) < 1e-12
  AND min_subnormal_pi.x = -5e-324
  AND min_subnormal_pi.y = 0.0
  AND min_subnormal_pi.z = 0.0
  AND min_subnormal_quarter_turn.x = 0.0
  AND min_subnormal_quarter_turn.y = 5e-324
  AND min_subnormal_quarter_turn.z = 0.0
FROM rotated;
----
true

# se3_apply null propagation for vec3/quat overloads
query I
SELECT se3_apply(CAST(NULL AS STRUCT(x DOUBLE, y DOUBLE, z DOUBLE)), struct_pack(x:=1.0, y:=2.0, z:=3.0)) IS NULL;
----
true

query I
SELECT se3_apply(struct_pack(x:=1.0, y:=2.0, z:=3.0), CAST(NULL AS STRUCT(x DOUBLE, y DOUBLE, z DOUBLE))) IS NULL;
----
true

query I
SELECT se3_apply(CAST(NULL AS STRUCT(w DOUBLE, x DOUBLE, y DOUBLE, z DOUBLE)), struct_pack(x:=1.0, y:=2.0, z:=3.0)) IS NULL;
----
true

# vec3 / vec4 constructors
query III
SELECT (vvec(1.0, 2.0, 3.0)).x, (vvec(1.0, 2.0, 3.0)).y, (vvec(1.0, 2.0, 3.0)).z;
----
1.0	2.0	3.0

query IIII
SELECT (vvec(1.0, 2.0, 3.0, 4.0)).w, (vvec(1.0, 2.0, 3.0, 4.0)).x, (vvec(1.0, 2.0, 3.0, 4.0)).y, (vvec(1.0, 2.0, 3.0, 4.0)).z;
----
1.0	2.0	3.0	4.0

# vector arithmetic (vec3 and vec4)
query III
SELECT
  (vadd(vvec(1.0, 2.0, 3.0), vvec(4.0, 5.0, 6.0))).x,
  (vadd(vvec(1.0, 2.0, 3.0), vvec(4.0, 5.0, 6.0))).y,
  (vadd(vvec(1.0, 2.0, 3.0), vvec(4.0, 5.0, 6.0))).z;
----
5.0	7.0	9.0

query IIII
SELECT
  (vsub(vvec(4.0, 3.0, 2.0, 1.0), vvec(1.0, 1.0, 1.0, 1.0))).w,
  (vsub(vvec(4.0, 3.0, 2.0, 1.0), vvec(1.0, 1.0, 1.0, 1.0))).x,
  (vsub(vvec(4.0, 3.0, 2.0, 1.0), vvec(1.0, 1.0, 1.0, 1.0))).y,
  (vsub(vvec(4.0, 3.0, 2.0, 1.0), vvec(1.0, 1.0, 1.0, 1.0))).z;
----
3.0	2.0	1.0	0.0

query III
SELECT
  (vscale(vvec(1.0, -2.0, 3.0), -2.0)).x,
  (vscale(vvec(1.0, -2.0, 3.0), -2.0)).y,
  (vscale(vvec(1.0, -2.0, 3.0), -2.0)).z;
----
-2.0	4.0	-6.0

# dot/norm/normalize
query II
SELECT vdot(vvec(1.0, 2.0, 3.0), vvec(4.0, 5.0, 6.0)),
       vdot(vvec(1.0, 2.0, 3.0, 4.0), vvec(4.0, 3.0, 2.0, 1.0));
----
32.0	20.0

query II
SELECT vnorm2(vvec(1.0, 2.0, 2.0)),
       vnorm(vvec(1.0, 2.0, 2.0, 1.0));
----
9.0	3.1622776601683795

query I
SELECT abs(vnorm(vnormalize(vvec(3.0, 4.0, 0.0))) - 1.0) < 1e-12;
----
true

query I
SELECT abs(vnorm(vnormalize(vvec(1.0, 2.0, 2.0, 1.0))) - 1.0) < 1e-12;
----
true

# cross / angle / projection / rejection
query III
SELECT
  (vcross(vvec(1.0, 0.0, 0.0), vvec(0.0, 1.0, 0.0))).x,
  (vcross(vvec(1.0, 0.0, 0.0), vvec(0.0, 1.0, 0.0))).y,
  (vcross(vvec(1.0, 0.0, 0.0), vvec(0.0, 1.0, 0.0))).z;
----
0.0	0.0	1.0

query II
SELECT vcos_angle(vvec(1.0, 0.0, 0.0), vvec(0.0, 1.0, 0.0)),
       round(vangle(vvec(1.0, 0.0, 0.0, 0.0), vvec(0.0, 1.0, 0.0, 0.0)), 12);
----
0.0	1.570796326795

query I
SELECT
  abs((vproj(vvec(3.0, 4.0, 0.0), vvec(1.0, 0.0, 0.0))).x - 3.0) < 1e-12
  AND abs((vproj(vvec(3.0, 4.0, 0.0), vvec(1.0, 0.0, 0.0))).y - 0.0) < 1e-12
  AND abs((vrej(vvec(3.0, 4.0, 0.0), vvec(1.0, 0.0, 0.0))).x - 0.0) < 1e-12
  AND abs((vrej(vvec(3.0, 4.0, 0.0), vvec(1.0, 0.0, 0.0))).y - 4.0) < 1e-12;
----
true

# zero-denominator cases follow floating-point semantics (NaN/Inf), not NULL
query I
SELECT isnan((vnormalize(vvec(0.0, 0.0, 0.0))).x);
----
true

query I
SELECT isnan((vnormalize(vvec(0.0, 0.0, 0.0, 0.0))).w);
----
true

query IIIIIIIIIIII
SELECT
  abs(vnorm(vvec(1e308, 0.0, 0.0)) / 1e308 - 1.0) < 1e-12,
  abs((vnormalize(vvec(1e308, 0.0, 0.0))).x - 1.0) < 1e-12,
  abs(vnorm(vvec(1e-300, 0.0, 0.0)) / 1e-300 - 1.0) < 1e-12,
  abs((vnormalize(vvec(1e-300, 0.0, 0.0))).x - 1.0) < 1e-12,
  abs(vnorm(vvec(1e-320, 0.0, 0.0)) / 1e-320 - 1.0) < 1e-12,
  abs((vnormalize(vvec(1e-320, 0.0, 0.0))).x - 1.0) < 1e-12,
  abs(vnorm(vvec(1e308, 0.0, 0.0, 0.0)) / 1e308 - 1.0) < 1e-12,
  abs((vnormalize(vvec(1e308, 0.0, 0.0, 0.0))).w - 1.0) < 1e-12,
  abs(vnorm(vvec(1e-300, 0.0, 0.0, 0.0)) / 1e-300 - 1.0) < 1e-12,
  abs((vnormalize(vvec(1e-300, 0.0, 0.0, 0.0))).w - 1.0) < 1e-12,
  abs(vnorm(vvec(1e-320, 0.0, 0.0, 0.0)) / 1e-320 - 1.0) < 1e-12,
  abs((vnormalize(vvec(1e-320, 0.0, 0.0, 0.0))).w - 1.0) < 1e-12;
----
true	true	true	true	true	true	true	true	true	true	true	true

query IIII
SELECT
  abs(vnorm(vvec(1e308, 1e308, 0.0)) / 1e308 - sqrt(2.0)) < 1e-12,
  abs((vnormalize(vvec(1e308, 1e308, 0.0))).x - 1.0 / sqrt(2.0)) < 1e-12,
  abs(vnorm(vvec(1e308, 1e308, 0.0, 0.0)) / 1e308 - sqrt(2.0)) < 1e-12,
  abs((vnormalize(vvec(1e308, 1e308, 0.0, 0.0))).w - 1.0 / sqrt(2.0)) < 1e-12;
----
true	true	true	true

query IIIIIIII
SELECT
  abs(vnorm(vvec(1e-160, 0.0, 0.0)) / 1e-160 - 1.0) < 1e-12,
  abs((vnormalize(vvec(1e-160, 0.0, 0.0))).x - 1.0) < 1e-12,
  abs(vnorm(vvec(1e-160, 1e-160, 0.0)) / (sqrt(2.0) * 1e-160) - 1.0) < 1e-12,
  abs((vnormalize(vvec(1e-160, 1e-160, 0.0))).x - 1.0 / sqrt(2.0)) < 1e-12,
  abs(vnorm(vvec(1e-160, 0.0, 0.0, 0.0)) / 1e-160 - 1.0) < 1e-12,
  abs((vnormalize(vvec(1e-160, 0.0, 0.0, 0.0))).w - 1.0) < 1e-12,
  abs(vnorm(vvec(1e-160, 1e-160, 0.0, 0.0)) / (sqrt(2.0) * 1e-160) - 1.0) < 1e-12,
  abs((vnormalize(vvec(1e-160, 1e-160, 0.0, 0.0))).w - 1.0 / sqrt(2.0)) < 1e-12;
----
true	true	true	true	true	true	true	true

query III
SELECT
  isinf(vnorm(vvec(1e308, 1e308, 1e308, 1e308))),
  abs((vnormalize(vvec(1e308, 1e308, 1e308))).x - 1.0 / sqrt(3.0)) < 1e-12,
  abs((vnormalize(vvec(1e308, 1e308, 1e308, 1e308))).w - 0.5) < 1e-12;
----
true	true	true

query IIII
SELECT
  abs((vnormalize(vvec(-1e308, 0.0, 0.0))).x + 1.0) < 1e-12,
  abs((vnormalize(vvec(-1e-320, 0.0, 0.0))).x + 1.0) < 1e-12,
  abs((vnormalize(vvec(-1e308, 0.0, 0.0, 0.0))).w + 1.0) < 1e-12,
  abs((vnormalize(vvec(-1e-320, 0.0, 0.0, 0.0))).w + 1.0) < 1e-12;
