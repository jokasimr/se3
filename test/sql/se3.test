true

# se3_compose(W, t) equals apply t then W
query I
SELECT
  round((se3_apply(
    se3_compose(
      se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0)),
      struct_pack(x:=0.0, y:=2.0, z:=0.0)
    ),
    struct_pack(x:=1.0, y:=1.0, z:=1.0)
  )).y, 6) = round((se3_apply(
    se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), struct_pack(w:=1.0, x:=0.0, y:=0.0, z:=0.0)),
    struct_pack(x:=1.0, y:=3.0, z:=1.0)
  )).y, 6);
