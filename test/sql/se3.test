# se3_from_axis_angle null propagation coverage
query I
SELECT se3_from_axis_angle(
  CAST(NULL AS STRUCT(x DOUBLE, y DOUBLE, z DOUBLE)),
  struct_pack(x:=1.0, y:=0.0, z:=0.0),
  pi()/2.0
) IS NULL;
----
true

query I
SELECT se3_from_axis_angle(
  struct_pack(x:=1.0, y:=2.0, z:=3.0),
  CAST(NULL AS STRUCT(x DOUBLE, y DOUBLE, z DOUBLE)),
  pi()/2.0
) IS NULL;
