# se3_inv(vec3) negates translation
query III
SELECT
  (se3_inv(struct_pack(x:=1.0, y:=-2.0, z:=3.0))).x,
  (se3_inv(struct_pack(x:=1.0, y:=-2.0, z:=3.0))).y,
  (se3_inv(struct_pack(x:=1.0, y:=-2.0, z:=3.0))).z;
----
-1.0	2.0	-3.0

# se3_inv(quat) conjugates quaternion
query IIII
SELECT
  (se3_inv(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0))).w,
  (se3_inv(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0))).x,
  (se3_inv(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0))).y,
  (se3_inv(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0))).z;
----
1.0	-2.0	-3.0	-4.0

# se3_inv(W) is inverse: W_inv(W(p)) = p
query I
SELECT
  round((se3_apply(
    se3_inv(se3_make(struct_pack(x:=1.0, y:=2.0, z:=3.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0))),
    se3_apply(
      se3_make(struct_pack(x:=1.0, y:=2.0, z:=3.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
      struct_pack(x:=4.0, y:=5.0, z:=6.0)
    )
  )).x, 6) = 4.0
  AND round((se3_apply(
    se3_inv(se3_make(struct_pack(x:=1.0, y:=2.0, z:=3.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0))),
    se3_apply(
      se3_make(struct_pack(x:=1.0, y:=2.0, z:=3.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
      struct_pack(x:=4.0, y:=5.0, z:=6.0)
    )
  )).y, 6) = 5.0
  AND round((se3_apply(
    se3_inv(se3_make(struct_pack(x:=1.0, y:=2.0, z:=3.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0))),
    se3_apply(
      se3_make(struct_pack(x:=1.0, y:=2.0, z:=3.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
      struct_pack(x:=4.0, y:=5.0, z:=6.0)
    )
  )).z, 6) = 6.0;
----
true

# se3_inv(W) avoids intermediate overflow for extreme finite translations
query I
WITH w AS (
  SELECT se3_inv(se3_make(vvec(1e308, 0.0, 0.0), vvec(0.0, 0.0, 0.0, 1.0))) AS inv_w
)
SELECT
  NOT isinf(inv_w.t.x) AND NOT isnan(inv_w.t.x)
  AND NOT isinf(inv_w.t.y) AND NOT isnan(inv_w.t.y)
  AND NOT isinf(inv_w.t.z) AND NOT isnan(inv_w.t.z)
  AND abs(inv_w.t.x / 1e308 - 1.0) < 1e-12
  AND abs(inv_w.t.y / 1e308) < 1e-12
  AND abs(inv_w.t.z / 1e308) < 1e-12
FROM w;
----
true

