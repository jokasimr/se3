        se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q2),
        se3_apply(
          se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q1),
          struct_pack(x:=px, y:=py, z:=pz)
        )
      )).x) < 1e-10
  AND abs((se3_apply(
        se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), qmul(q2, q1)),
        struct_pack(x:=px, y:=py, z:=pz)
      )).y - (se3_apply(
        se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q2),
        se3_apply(
          se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q1),
          struct_pack(x:=px, y:=py, z:=pz)
        )
      )).y) < 1e-10
  AND abs((se3_apply(
        se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), qmul(q2, q1)),
        struct_pack(x:=px, y:=py, z:=pz)
      )).z - (se3_apply(
        se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q2),
        se3_apply(
          se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), q1),
          struct_pack(x:=px, y:=py, z:=pz)
        )
      )).z) < 1e-10
)
FROM q;
----
true

# se3_compose(vec3, vec3) adds translations
query III
SELECT
  (se3_compose(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(x:=4.0, y:=5.0, z:=6.0))).x,
  (se3_compose(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(x:=4.0, y:=5.0, z:=6.0))).y,
  (se3_compose(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(x:=4.0, y:=5.0, z:=6.0))).z;
----
5.0	7.0	9.0

# se3_compose(quat, quat) equals qmul
query IIII
SELECT
  (se3_compose(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0), struct_pack(w:=5.0, x:=6.0, y:=7.0, z:=8.0))).w,
  (qmul(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0), struct_pack(w:=5.0, x:=6.0, y:=7.0, z:=8.0))).w,
  (se3_compose(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0), struct_pack(w:=5.0, x:=6.0, y:=7.0, z:=8.0))).x,
  (qmul(struct_pack(w:=1.0, x:=2.0, y:=3.0, z:=4.0), struct_pack(w:=5.0, x:=6.0, y:=7.0, z:=8.0))).x;
----
-60.0	-60.0	12.0	12.0

# se3_compose(q, t): apply t then rotate (result equals {t, q})
query III
SELECT
  round((se3_apply(
    se3_compose(quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0), struct_pack(x:=1.0, y:=0.0, z:=0.0)),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).x, 6),
  round((se3_apply(
    se3_compose(quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0), struct_pack(x:=1.0, y:=0.0, z:=0.0)),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).y, 6),
  round((se3_apply(
    se3_compose(quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0), struct_pack(x:=1.0, y:=0.0, z:=0.0)),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).z, 6);
----
0.0	1.0	0.0

# se3_compose(t, q): apply q then t (t' = R^-1 t)
query III
SELECT
  round((se3_apply(
    se3_compose(struct_pack(x:=1.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).x, 6),
  round((se3_apply(
    se3_compose(struct_pack(x:=1.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).y, 6),
  round((se3_apply(
    se3_compose(struct_pack(x:=1.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
    struct_pack(x:=0.0, y:=0.0, z:=0.0)
  )).z, 6);
----
1.0	0.0	0.0

# se3_compose(W2, W1) equals sequential application
query I
SELECT
  round((se3_apply(
    se3_compose(
      se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
      se3_make(struct_pack(x:=0.0, y:=1.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0))
    ),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).x, 6) = round((se3_apply(
    se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
    se3_apply(
      se3_make(struct_pack(x:=0.0, y:=1.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
      struct_pack(x:=1.0, y:=0.0, z:=0.0)
    )
  )).x, 6)
  AND round((se3_apply(
    se3_compose(
      se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
      se3_make(struct_pack(x:=0.0, y:=1.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0))
    ),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).y, 6) = round((se3_apply(
    se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
    se3_apply(
      se3_make(struct_pack(x:=0.0, y:=1.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
      struct_pack(x:=1.0, y:=0.0, z:=0.0)
    )
  )).y, 6)
  AND round((se3_apply(
    se3_compose(
      se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
      se3_make(struct_pack(x:=0.0, y:=1.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0))
    ),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).z, 6) = round((se3_apply(
    se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
    se3_apply(
      se3_make(struct_pack(x:=0.0, y:=1.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
      struct_pack(x:=1.0, y:=0.0, z:=0.0)
    )
  )).z, 6);
----
true

# se3_compose(W, q) equals apply q then W
query I
SELECT
  round((se3_apply(
    se3_compose(
      se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
      quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)
    ),
    struct_pack(x:=1.0, y:=0.0, z:=0.0)
  )).x, 6) = round((se3_apply(
    se3_make(struct_pack(x:=1.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
    se3_apply(
      se3_make(struct_pack(x:=0.0, y:=0.0, z:=0.0), quat_from_axis_angle(struct_pack(x:=0.0, y:=0.0, z:=1.0), pi()/2.0)),
      struct_pack(x:=1.0, y:=0.0, z:=0.0)
    )
  )).x, 6);
