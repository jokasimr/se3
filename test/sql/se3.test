                 CAST(NULL AS STRUCT(x DOUBLE, y DOUBLE, z DOUBLE))) IS NULL;
----
true

query I
SELECT se3_apply(CAST(NULL AS STRUCT(w DOUBLE, x DOUBLE, y DOUBLE, z DOUBLE)),
                 struct_pack(x:=1.0, y:=2.0, z:=3.0)) IS NULL;
