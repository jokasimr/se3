query I
SELECT
  abs((vadd(vproj(vvec(1.0, 2.0, 3.0, 4.0), vvec(4.0, 3.0, 2.0, 1.0)),
            vrej(vvec(1.0, 2.0, 3.0, 4.0), vvec(4.0, 3.0, 2.0, 1.0)))).w - 1.0) < 1e-12
  AND abs((vadd(vproj(vvec(1.0, 2.0, 3.0, 4.0), vvec(4.0, 3.0, 2.0, 1.0)),
                vrej(vvec(1.0, 2.0, 3.0, 4.0), vvec(4.0, 3.0, 2.0, 1.0)))).x - 2.0) < 1e-12
  AND abs((vadd(vproj(vvec(1.0, 2.0, 3.0, 4.0), vvec(4.0, 3.0, 2.0, 1.0)),
                vrej(vvec(1.0, 2.0, 3.0, 4.0), vvec(4.0, 3.0, 2.0, 1.0)))).y - 3.0) < 1e-12
  AND abs((vadd(vproj(vvec(1.0, 2.0, 3.0, 4.0), vvec(4.0, 3.0, 2.0, 1.0)),
                vrej(vvec(1.0, 2.0, 3.0, 4.0), vvec(4.0, 3.0, 2.0, 1.0)))).z - 4.0) < 1e-12;
