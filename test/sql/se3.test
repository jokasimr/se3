  (se3_apply(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(x:=4.0, y:=5.0, z:=6.0))).x,
  (se3_apply(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(x:=4.0, y:=5.0, z:=6.0))).y,
  (se3_apply(struct_pack(x:=1.0, y:=2.0, z:=3.0), struct_pack(x:=4.0, y:=5.0, z:=6.0))).z;
