true

# vproj/vrej should avoid intermediate overflow/underflow for finite non-zero projection axes
query IIIIIIIIIIII
SELECT
  abs((vproj(vvec(1e200, 0.0, 0.0), vvec(1e200, 0.0, 0.0))).x / 1e200 - 1.0) < 1e-12,
  abs((vrej(vvec(1e200, 0.0, 0.0), vvec(1e200, 0.0, 0.0))).x) < 1e-12,
  abs((vproj(vvec(1e-200, 0.0, 0.0), vvec(1e-200, 0.0, 0.0))).x / 1e-200 - 1.0) < 1e-12,
  abs((vrej(vvec(1e-200, 1.0, 0.0), vvec(1e-200, 0.0, 0.0))).y - 1.0) < 1e-12,
  abs((vproj(vvec(1.0, 0.0, 0.0), vvec(1e200, 0.0, 0.0))).x - 1.0) < 1e-12,
  abs((vproj(vvec(0.0, 1.0, 0.0), vvec(1e-200, 0.0, 0.0))).x) < 1e-12,
  abs((vproj(vvec(1e200, 0.0, 0.0, 0.0), vvec(1e200, 0.0, 0.0, 0.0))).w / 1e200 - 1.0) < 1e-12,
  abs((vrej(vvec(1e200, 0.0, 0.0, 0.0), vvec(1e200, 0.0, 0.0, 0.0))).w) < 1e-12,
  abs((vproj(vvec(1e-200, 0.0, 0.0, 0.0), vvec(1e-200, 0.0, 0.0, 0.0))).w / 1e-200 - 1.0) < 1e-12,
  abs((vrej(vvec(1e-200, 1.0, 0.0, 0.0), vvec(1e-200, 0.0, 0.0, 0.0))).x - 1.0) < 1e-12,
  abs((vproj(vvec(1.0, 0.0, 0.0, 0.0), vvec(1e200, 0.0, 0.0, 0.0))).w - 1.0) < 1e-12,
  abs((vproj(vvec(0.0, 1.0, 0.0, 0.0), vvec(1e-200, 0.0, 0.0, 0.0))).w) < 1e-12;
----
true	true	true	true	true	true	true	true	true	true	true	true

query IIIIII
SELECT
  abs((vproj(vvec(1.0, 0.0, 0.0), vvec(1e-320, 0.0, 0.0))).x - 1.0) < 1e-12,
  abs((vrej(vvec(1e-320, 1.0, 0.0), vvec(1e-320, 0.0, 0.0))).y - 1.0) < 1e-12,
  abs((vproj(vvec(0.0, 1.0, 0.0), vvec(1e-320, 0.0, 0.0))).x) < 1e-12,
  abs((vproj(vvec(1.0, 0.0, 0.0, 0.0), vvec(1e-320, 0.0, 0.0, 0.0))).w - 1.0) < 1e-12,
  abs((vrej(vvec(1e-320, 1.0, 0.0, 0.0), vvec(1e-320, 0.0, 0.0, 0.0))).x - 1.0) < 1e-12,
  abs((vproj(vvec(0.0, 1.0, 0.0, 0.0), vvec(1e-320, 0.0, 0.0, 0.0))).w) < 1e-12;
----
true	true	true	true	true	true

query IIIIII
SELECT
  abs((vproj(vvec(1e308, 1e308, 0.0), vvec(1e200, -1e200, 0.0))).x) < 1e-12,
  abs((vproj(vvec(1e308, 1e308, 0.0), vvec(1e200, -1e200, 0.0))).y) < 1e-12,
  abs((vrej(vvec(1e308, 1e308, 0.0), vvec(1e200, -1e200, 0.0))).x / 1e308 - 1.0) < 1e-12,
  abs((vproj(vvec(1e308, 1e308, 0.0, 0.0), vvec(1e200, -1e200, 0.0, 0.0))).w) < 1e-12,
  abs((vproj(vvec(1e308, 1e308, 0.0, 0.0), vvec(1e200, -1e200, 0.0, 0.0))).x) < 1e-12,
  abs((vrej(vvec(1e308, 1e308, 0.0, 0.0), vvec(1e200, -1e200, 0.0, 0.0))).w / 1e308 - 1.0) < 1e-12;
----
true	true	true	true	true	true

# vcos_angle/vangle should avoid intermediate overflow/underflow for finite non-zero vectors
query IIIIIIIIIIII
SELECT
  abs(vcos_angle(vvec(1e200, 0.0, 0.0), vvec(1e200, 0.0, 0.0)) - 1.0) < 1e-12,
  abs(vangle(vvec(1e200, 0.0, 0.0), vvec(1e200, 0.0, 0.0))) < 1e-12,
  abs(vcos_angle(vvec(1e-200, 0.0, 0.0), vvec(1e-200, 0.0, 0.0)) - 1.0) < 1e-12,
  abs(vangle(vvec(1e-200, 0.0, 0.0), vvec(1e-200, 0.0, 0.0))) < 1e-12,
  abs(vcos_angle(vvec(1e100, 0.0, 0.0), vvec(1e100, 0.0, 0.0)) - 1.0) < 1e-12,
  abs(vangle(vvec(1e100, 0.0, 0.0), vvec(1e100, 0.0, 0.0))) < 1e-12,
  abs(vcos_angle(vvec(1e-100, 0.0, 0.0), vvec(1e-100, 0.0, 0.0)) - 1.0) < 1e-12,
  abs(vangle(vvec(1e-100, 0.0, 0.0), vvec(1e-100, 0.0, 0.0))) < 1e-12,
  abs(vcos_angle(vvec(1e-80, 0.0, 0.0), vvec(1e-80, 0.0, 0.0)) - 1.0) < 1e-12,
  abs(vangle(vvec(1e-80, 0.0, 0.0), vvec(1e-80, 0.0, 0.0))) < 1e-12,
  abs(vcos_angle(vvec(1e-320, 0.0, 0.0), vvec(1e-320, 0.0, 0.0)) - 1.0) < 1e-12,
  abs(vangle(vvec(1e-320, 0.0, 0.0), vvec(1e-320, 0.0, 0.0))) < 1e-12;
----
true	true	true	true	true	true	true	true	true	true	true	true

query IIII
SELECT
  abs(vcos_angle(vvec(1e200, 0.0, 0.0), vvec(0.0, 1e200, 0.0))) < 1e-12,
  abs(vangle(vvec(1e200, 0.0, 0.0), vvec(0.0, 1e200, 0.0)) - pi()/2.0) < 1e-12,
  abs(vcos_angle(vvec(1e200, 0.0, 0.0, 0.0), vvec(0.0, 1e200, 0.0, 0.0))) < 1e-12,
  abs(vangle(vvec(1e200, 0.0, 0.0, 0.0), vvec(0.0, 1e200, 0.0, 0.0)) - pi()/2.0) < 1e-12;
----
true	true	true	true

# vangle clamps finite cosine roundoff near +/-1
query IIII
WITH vals AS (
  SELECT
    vvec(3.14162798704748e-138, 2.268453554966467e-138, 2.172250743988824e-138) AS a3,
    vvec(3.141627987045909e-138, 2.2684535549653328e-138, 2.172250743987738e-138) AS b3,
    vvec(2.6595387577548104e-143, 3.3902715549111994e-143, 2.31528056255824e-143, 1.3788669018291794e-143) AS a4,
    vvec(2.65953875775348e-143, 3.3902715549095037e-143, 2.3152805625570823e-143, 1.37886690182849e-143) AS b4
)
SELECT
  abs(vcos_angle(a3, b3) - 1.0) < 1e-12 AND abs(vangle(a3, b3)) < 1e-12,
  abs(vcos_angle(a3, vscale(b3, -1.0)) + 1.0) < 1e-12 AND abs(vangle(a3, vscale(b3, -1.0)) - pi()) < 1e-12,
  abs(vcos_angle(a4, b4) - 1.0) < 1e-12 AND abs(vangle(a4, b4)) < 1e-12,
  abs(vcos_angle(a4, vscale(b4, -1.0)) + 1.0) < 1e-12 AND abs(vangle(a4, vscale(b4, -1.0)) - pi()) < 1e-12
FROM vals;
----
true	true	true	true

